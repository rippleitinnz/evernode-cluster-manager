# Evernode Cluster Manager — Configuration
# Copy this file to .env and fill in your values.
# Or run setup.sh to generate automatically.

# ── Project ───────────────────────────────────────────
PROJECT_DIR=/home/youruser/evernode_client

# ── XRPL Tenant Identity ──────────────────────────────
EV_TENANT_SECRET=
EV_TENANT_ADDRESS=
EV_USER_PRIVATE_KEY=
EV_USER_PUBLIC_KEY=

# ── Cluster Defaults ──────────────────────────────────
DEFAULT_NODE_COUNT=3
DEFAULT_MOMENTS=3

# ── HotPocket Settings ────────────────────────────────
HP_ROUNDTIME=5000
HP_THRESHOLD=66
HP_LOG_LEVEL=dbg
HP_PEER_DISCOVERY=false

# ── Contract ──────────────────────────────────────────
CONTRACT_VERSION=v1.0.0
